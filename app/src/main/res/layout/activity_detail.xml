<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/header_dark"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/header_dark"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/ivDetailIcon"
                    android:layout_width="96dp"
                    android:layout_height="96dp" />

                <TextView
                    android:id="@+id/tvDetailTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="@color/white"
                    android:textSize="56sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_blue"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvDetailFeels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/tvDetailTempMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_blue"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  |  "
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvDetailTempMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_blue"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Info Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="12dp"
                android:rowCount="4">

                <!-- Kelembapan -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💧 Kelembapan" android:textColor="@color/text_muted" android:textSize="12sp" />
                        <TextView android:id="@+id/tvDetailHumidity" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Angin -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💨 Angin" android:textColor="@color/text_muted" android:textSize="12sp" />
                        <TextView android:id="@+id/tvDetailWind" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                        <TextView android:id="@+id/tvDetailWindDir" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tekanan -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌡️ Tekanan" android:textColor="@color/text_muted" android:textSize="12sp" />
                        <TextView android:id="@+id/tvDetailPressure" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Visibilitas -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👁️ Visibilitas" android:textColor="@color/text_muted" android:textSize="12sp" />
                        <TextView android:id="@+id/tvDetailVisibility" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tutupan Awan -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="☁️ Tutupan Awan" android:textColor="@color/text_muted" android:textSize="12sp" />
                        <TextView android:id="@+id/tvDetailClouds" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Matahari -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="🌅 Terbit" android:textColor="@color/text_muted" android:textSize="11sp" />
                                <TextView android:id="@+id/tvDetailSunrise" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--:--"
                                    android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="🌇 Tenggelam" android:textColor="@color/text_muted" android:textSize="11sp" />
                                <TextView android:id="@+id/tvDetailSunset" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--:--"
                                    android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- Prakiraan Per Jam -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                android:text="PER JAM" android:textColor="@color/text_muted" android:textSize="11sp"
                android:letterSpacing="0.1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHourly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false" />

            <!-- Prakiraan Harian -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"
                android:text="7 HARI KE DEPAN" android:textColor="@color/text_muted" android:textSize="11sp"
                android:letterSpacing="0.1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDaily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
