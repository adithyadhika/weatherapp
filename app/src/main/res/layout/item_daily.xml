<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Hari -->
    <TextView
        android:id="@+id/tvDayName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:text="Sen"
        android:textColor="#8AB4D8"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Deskripsi -->
    <TextView
        android:id="@+id/tvDayDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Cerah"
        android:textColor="#7A9FC4"
        android:textSize="12sp" />

    <!-- Icon -->
    <ImageView
        android:id="@+id/ivDayIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp" />

    <!-- Suhu Min -->
    <TextView
        android:id="@+id/tvDayMin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--°"
        android:textColor="#7A9FC4"
        android:textSize="14sp"
        android:minWidth="32dp"
        android:gravity="end" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" – "
        android:textColor="#5A7A9A"
        android:textSize="14sp" />

    <!-- Suhu Max -->
    <TextView
        android:id="@+id/tvDayMax"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--°"
        android:textColor="#C8DDF0"
        android:textSize="14sp"
        android:textStyle="bold"
        android:minWidth="32dp" />

</LinearLayout>
